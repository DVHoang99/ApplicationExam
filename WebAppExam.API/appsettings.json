{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=mydatabase;Username=myuser;Password=mypassword;"
  },
  "Kafka": {
    "BootstrapServers": "kafka:9092"
  },
  "MongoDb": {
    "ConnectionString": "mongodb://admin:adminpassword@mongodb:27017",
    "DatabaseName": "mydatabase"
  },
  "Redis": {
    "Configuration": "redis:6379,password=adminpassword"
  }
}
